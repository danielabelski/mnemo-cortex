# ─────────────────────────────────────────────
# Mnemo Cortex v0.8.0 Configuration
# "I remember everything so your agent doesn't have to."
# https://github.com/GuyMannDude/mnemo-cortex
# ─────────────────────────────────────────────
# What's new in v0.8.0:
#   - Phase 3 Facts table — structured (entity, attribute, value) lookups
#     with three-state confidence (verified > high_probability > false)
#     and audit history. New MCP tools: mnemo_fact_get / query / save /
#     demote. Storage auto-creates at ~/.agentb/facts.sqlite (no config
#     needed).
#   - Dreamer Stage 0.5 — nightly cron auto-extracts facts from new
#     memories with a conservative-only-direct-statements prompt and
#     posts contradictions to bus + Discord (both opt-in via env vars).
#   - sqlite-vec primary index (Phase 2) — hybrid FTS5+vector recall.
#   - Adaptive truncation on input-too-long (v2.11.x) — no more 503
#     flapping on oversized recall queries.
#   - Embedding hosted fallback — Google gemini-embedding-001 with
#     Matryoshka truncation to match the local 768-dim store (example
#     below).

data_dir: ~/.agentb
log_level: info

# ── Reasoning Provider (with fallback chain) ──
# Used for preflight checks, summarization, and Dreamer synthesis.
# If primary fails, falls through to fallbacks. Sparks default ships
# OpenRouter primary because gemini-2.5-flash gives sharper Dreamer
# briefs at near-zero cost; local Ollama is a no-cost fallback.
reasoning:
  provider: openrouter
  model: google/gemini-2.5-flash
  api_key: ${OPENROUTER_API_KEY}
  api_base: https://openrouter.ai/api/v1
  timeout: 30

  # Circuit breaker: skip primary after N failures, retry after cooldown
  circuit_breaker_threshold: 3
  circuit_breaker_cooldown: 60

  fallbacks:
    - provider: ollama
      model: qwen2.5:32b-instruct
      api_base: http://localhost:11434
    # - provider: openai
    #   model: gpt-4o-mini
    #   api_key: ${OPENAI_API_KEY}
    #   timeout: 15

# ── Embedding Provider (with fallback chain) ──
# Embedding powers all recall (semantic similarity). Local Ollama is
# cheap, fast, and the right default. Hosted fallback covers the
# "Ollama is down" case — without it, every recall 500s during outages.
#
# Dimension lock: sqlite-vec store is 768 dims (nomic-embed-text native).
# If your fallback provider's native dim doesn't match 768, use the
# `extra.output_dimensionality` parameter (supported by Google's
# gemini-embedding-* family via Matryoshka truncation) to coerce.
embedding:
  provider: ollama
  model: nomic-embed-text
  api_base: http://localhost:11434

  fallbacks:
    # Recommended hosted fallback: Google's gemini-embedding-001 with
    # Matryoshka truncation to 768 dims. Free tier (1500 embeds/day) covers
    # any plausible Ollama-outage window.
    - provider: google
      model: gemini-embedding-001
      api_key: ${GOOGLE_API_KEY}
      timeout: 15
      extra:
        output_dimensionality: 768  # truncates 3072 native → 768 to match store

    # Alternative: OpenAI text-embedding-3-small (note: needs a provider
    # patch to pass the dimensions parameter — see GoogleEmbedding for
    # reference. Defaults to 1536 dims which WILL trip the vec dim guard).
    # - provider: openai
    #   model: text-embedding-3-small
    #   api_key: ${OPENAI_API_KEY}

# ── Cache Settings ──
cache:
  l1_max_bundles: 50
  l1_ttl_seconds: 86400
  l1_similarity_threshold: 0.75
  l2_similarity_threshold: 0.5
  l3_similarity_threshold: 0.4

# ── Server Settings ──
server:
  host: 0.0.0.0
  port: 50001
  cors_origins: ["*"]
  # FAIL-CLOSED: with a non-loopback host (e.g. 0.0.0.0) the server REFUSES to
  # start unless auth is configured. Fix by one of: set auth_token below, bind
  # host: 127.0.0.1 (loopback only), or set allow_unauthenticated: true for a
  # deliberately open deploy behind an external gatekeeper (private net / proxy).
  # allow_unauthenticated: false
  # auth_token: my-secret-token   # require X-API-KEY header (master — full access)
  # Scoped tokens (v4.9): pin a token to ONE agent tenant + an endpoint
  # allowlist, so a less-trusted caller never holds the master key. Only
  # /context, /writeback, /trajectory/save, /trajectory/recall can be scoped.
  # Paths match EXACTLY (fail-closed, checked before routing): a scoped call
  # to "/writeback/" (trailing slash) gets 403, not a redirect — use the
  # exact path.
  # scoped_tokens:
  #   - token: "${MNEMO_TOKEN_HELPER}"
  #     agent_id: helper
  #     endpoints: ["/context", "/writeback"]

# ── Persona Modes ──
# Built-in: default, strict, creative. Custom personas overlay these:
personas:
  # Example: ultra-strict for financial/legal work
  # financial:
  #   preflight: aggressive
  #   context_bias: factual
  #   max_confidence_for_pass: 0.95
  #   allow_speculative: false
  #   custom_system_prompt: >
  #     Verify all dollar amounts, dates, and contract terms.
  #     BLOCK any response with unverified financial claims.

  # Example: brainstorm mode for product ideation
  # brainstorm:
  #   preflight: permissive
  #   context_bias: associative
  #   max_confidence_for_pass: 0.3
  #   allow_speculative: true
  #   l1_similarity_override: 0.5
  #   l2_similarity_override: 0.3

# ── Multi-Agent Isolation ──
# Each agent gets its own memory namespace at ~/.agentb/agents/<id>/memory/.
# Mnemo auto-creates the directory tree on first save. The example below
# pre-registers two agents at startup; agents created via runtime saves
# work without explicit declaration.
agents:
  # main:
  #   persona: default
  # researcher:
  #   persona: strict

# ── Phase 3 Facts (NEW in v0.8.0) ──
# No config needed. The shared global facts store auto-creates at
# ~/.agentb/facts.sqlite on first POST to /facts. Three new HTTP routes
# (/facts, /facts/{e}/{a}, /facts/demote, /facts/history, /facts/contradictions)
# and four MCP tools (mnemo_fact_get/query/save/demote) wire up automatically.

# ── Session Capture (The Live Wire) ──
# Sessions captured automatically via /ingest. Settings control lifecycle:
# sessions:
#   hot_days: 3              # days in hot storage (instant search)
#   warm_days: 30            # days in warm storage (summarized, indexed)
#   max_session_gap_minutes: 60  # start new session after this gap
#   auto_summarize: true     # summarize sessions on archival
#   max_hot_entries: 500     # safety cap per session file

# ── Mem0 Upstream Bridge (Optional) ──
# Two-tier memory: local-first, cloud-deep. When local search misses,
# Mnemo falls through to Mem0's semantic vector search.
# mem0:
#   enabled: true
#   api_key: ${MEM0_API_KEY}
#   api_base: https://api.mem0.ai/v1
#   user_id: my-agent
#   fallback_only: true
#   sync_writes: false
#   min_relevance: 0.3
#   max_results: 3
#   timeout: 5.0

# ── Dreamer (mnemo-dream.py) — Environment variables ──
# The Dreamer script runs as a nightly cron, not from this YAML. It reads
# environment variables for its config. Set these in your cron's env file:
#
#   OPENROUTER_API_KEY    — for synthesis + fact extraction LLM calls
#   MNEMO_URL             — Mnemo HTTP base (default http://localhost:50001)
#   MNEMO_DREAM_MODEL     — synthesis model (default google/gemini-2.5-flash)
#   MNEMO_DREAM_AGENTS    — comma-separated agent allowlist; omit to
#                           auto-discover from ~/.agentb/agents/*/memory/
#   DREAM_SKIP_FACTS      — set to 1 to disable Stage 0.5 fact extraction
#
# Contradiction notification (opt-in, all three needed together):
#   MNEMO_DREAM_BUS_URL       — base URL of your bus/dispatcher
#   MNEMO_DREAM_BUS_FROM      — registered sender agent name
#   MNEMO_DREAM_BUS_TARGETS   — comma-separated registered receiver agents
#
# Direct human visibility (opt-in, independent of bus):
#   MNEMO_DREAM_DISCORD_WEBHOOK — Discord webhook URL
